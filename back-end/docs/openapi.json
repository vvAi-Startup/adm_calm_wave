{
  "openapi": "3.0.0",
  "info": {
    "title": "CalmWave API",
    "description": "API para plataforma de processamento de áudio com IA. Documentação completa de todas as rotas disponíveis.",
    "version": "1.0.0",
    "contact": {
      "name": "CalmWave Team",
      "email": "support@calmwave.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "profile_photo_url": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "last_access": { "type": "string", "format": "date-time" },
          "active": { "type": "boolean" },
          "account_type": { "type": "string", "enum": ["free", "premium", "admin"] },
          "role": { "type": "string" },
          "settings": {
            "type": "object",
            "properties": {
              "dark_mode": { "type": "boolean" },
              "notifications_enabled": { "type": "boolean" },
              "auto_process_audio": { "type": "boolean" },
              "audio_quality": { "type": "string", "enum": ["low", "normal", "high"] }
            }
          }
        }
      },
      "Audio": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "filename": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "size_bytes": { "type": "integer" },
          "recorded_at": { "type": "string", "format": "date-time" },
          "processed": { "type": "boolean" },
          "processing_time_ms": { "type": "integer" },
          "processing_error": { "type": "string", "nullable": true },
          "transcribed": { "type": "boolean" },
          "transcription_text": { "type": "string", "nullable": true },
          "favorite": { "type": "boolean" },
          "playlist_id": { "type": "integer", "nullable": true },
          "device_origin": { "type": "string" }
        }
      },
      "Playlist": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "name": { "type": "string" },
          "color": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "total_audios": { "type": "integer" },
          "order": { "type": "integer" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "user_id": { "type": "integer", "nullable": true },
          "title": { "type": "string" },
          "message": { "type": "string" },
          "type": { "type": "string" },
          "is_read": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "user_id": { "type": "integer", "nullable": true },
          "event_type": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "details_json": { "type": "string" },
          "screen": { "type": "string" },
          "level": { "type": "string", "enum": ["info", "warning", "error"] }
        }
      },
      "SupportTicket": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "subject": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "messages_count": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check da API",
        "description": "Verifica se a API está operacional e se o banco de dados responde.",
        "responses": {
          "200": {
            "description": "API operacional",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["ok", "degraded"] },
                    "service": { "type": "string" },
                    "version": { "type": "string" },
                    "uptime_seconds": { "type": "integer" },
                    "database": { "type": "string", "enum": ["ok", "unreachable"] },
                    "timestamp": { "type": "number" }
                  }
                }
              }
            }
          },
          "503": { "description": "Banco de dados inacessível" }
        }
      }
    },

    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrar novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" },
                  "account_type": { "type": "string", "enum": ["free", "premium"], "default": "free" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário registrado com sucesso" },
          "400": { "description": "Dados inválidos" },
          "409": { "description": "Email já cadastrado" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Fazer login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "refresh_token": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "401": { "description": "Credenciais inválidas" },
          "403": { "description": "Conta desativada" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Renovar token de acesso",
        "security": [{ "bearerAuth": [] }],
        "description": "Usa o refresh token no header Authorization para gerar um novo access token.",
        "responses": {
          "200": {
            "description": "Novo token gerado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "token": { "type": "string" } }
                }
              }
            }
          },
          "401": { "description": "Refresh token inválido ou expirado" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Dados do usuário autenticado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Dados do usuário",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Não autorizado" }
        }
      }
    },

    "/users/": {
      "get": {
        "tags": ["Users"],
        "summary": "Listar usuários",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Lista de usuários",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": { "type": "array", "items": { "$ref": "#/components/schemas/User" } },
                    "total": { "type": "integer" },
                    "pages": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/{user_id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Obter usuário por ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "user_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Dados do usuário", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Atualizar usuário",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "user_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "active": { "type": "boolean" },
                  "account_type": { "type": "string" },
                  "profile_photo_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Usuário atualizado" },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Deletar usuário",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "user_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Usuário deletado" },
          "404": { "description": "Usuário não encontrado" }
        }
      }
    },
    "/users/me/settings": {
      "put": {
        "tags": ["Users"],
        "summary": "Atualizar configurações do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dark_mode": { "type": "boolean" },
                  "notifications_enabled": { "type": "boolean" },
                  "auto_process_audio": { "type": "boolean" },
                  "audio_quality": { "type": "string", "enum": ["low", "normal", "high"] },
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Configurações atualizadas" } }
      }
    },
    "/users/me/devices": {
      "get": {
        "tags": ["Users"],
        "summary": "Listar dispositivos do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de dispositivos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "devices": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "device_name": { "type": "string" },
                          "device_type": { "type": "string" },
                          "ip_address": { "type": "string" },
                          "connected_at": { "type": "string", "format": "date-time" },
                          "last_active": { "type": "string", "format": "date-time" },
                          "is_current": { "type": "boolean" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/me/devices/{device_id}": {
      "delete": {
        "tags": ["Users"],
        "summary": "Revogar dispositivo específico",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "device_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Dispositivo revogado" } }
      }
    },
    "/users/me/devices/revoke_all": {
      "post": {
        "tags": ["Users"],
        "summary": "Revogar todos os dispositivos",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Todos os dispositivos revogados" } }
      }
    },
    "/users/me/achievements": {
      "get": {
        "tags": ["Users"],
        "summary": "Conquistas do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de conquistas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "achievements": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "icon": { "type": "string" },
                          "name": { "type": "string" },
                          "desc": { "type": "string" },
                          "earned": { "type": "boolean" },
                          "count": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/audios/upload": {
      "post": {
        "tags": ["Audios"],
        "summary": "Upload de áudio",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "device_origin": { "type": "string", "default": "Web" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Áudio enviado com sucesso", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Audio" } } } },
          "400": { "description": "Arquivo inválido ou ausente" }
        }
      }
    },
    "/audios/sync": {
      "post": {
        "tags": ["Audios"],
        "summary": "Sincronizar metadados de áudio mobile",
        "description": "Registra os metadados de um áudio armazenado no dispositivo mobile. Nenhum arquivo é enviado.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["filename"],
                "properties": {
                  "filename": { "type": "string" },
                  "duration_seconds": { "type": "number" },
                  "size_bytes": { "type": "integer" },
                  "device_origin": { "type": "string", "default": "Mobile" },
                  "recorded_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Metadados sincronizados", "content": { "application/json": { "schema": { "type": "object", "properties": { "audio": { "$ref": "#/components/schemas/Audio" } } } } } },
          "400": { "description": "Campo filename obrigatório" }
        }
      }
    },
    "/audios/batch-export": {
      "post": {
        "tags": ["Audios"],
        "summary": "Exportar áudios em lote (ZIP)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "audio_ids": { "type": "array", "items": { "type": "integer" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Arquivo ZIP com os áudios selecionados", "content": { "application/zip": {} } }
        }
      }
    },
    "/audios/play/{audio_id}": {
      "get": {
        "tags": ["Audios"],
        "summary": "Reproduzir áudio",
        "parameters": [
          { "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["original", "processed"], "default": "processed" } }
        ],
        "responses": {
          "200": { "description": "Stream de áudio", "content": { "audio/wav": {} } },
          "404": { "description": "Áudio não encontrado" }
        }
      }
    },
    "/audios/": {
      "get": {
        "tags": ["Audios"],
        "summary": "Listar áudios do usuário",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "processed", "in": "query", "schema": { "type": "boolean" } },
          { "name": "favorite", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Lista de áudios",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "audios": { "type": "array", "items": { "$ref": "#/components/schemas/Audio" } },
                    "total": { "type": "integer" },
                    "pages": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/audios/{audio_id}": {
      "get": {
        "tags": ["Audios"],
        "summary": "Obter áudio por ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Dados do áudio", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Audio" } } } },
          "404": { "description": "Áudio não encontrado" }
        }
      },
      "put": {
        "tags": ["Audios"],
        "summary": "Atualizar áudio",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "favorite": { "type": "boolean" },
                  "playlist_id": { "type": "integer", "nullable": true },
                  "transcription_text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Áudio atualizado" } }
      },
      "delete": {
        "tags": ["Audios"],
        "summary": "Deletar áudio",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Áudio deletado" } }
      }
    },
    "/audios/{audio_id}/reprocess": {
      "post": {
        "tags": ["Audios"],
        "summary": "Reprocessar áudio",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Reprocessamento iniciado" },
          "404": { "description": "Áudio não encontrado" }
        }
      }
    },

    "/playlists/": {
      "get": {
        "tags": ["Playlists"],
        "summary": "Listar playlists",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Lista de playlists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "playlists": { "type": "array", "items": { "$ref": "#/components/schemas/Playlist" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Playlists"],
        "summary": "Criar playlist",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "color": { "type": "string", "default": "#6FAF9E" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Playlist criada" } }
      }
    },
    "/playlists/{playlist_id}": {
      "get": {
        "tags": ["Playlists"],
        "summary": "Obter playlist por ID (inclui áudios)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "playlist_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Dados da playlist com áudios" } }
      },
      "put": {
        "tags": ["Playlists"],
        "summary": "Atualizar playlist",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "playlist_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "color": { "type": "string" },
                  "order": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Playlist atualizada" } }
      },
      "delete": {
        "tags": ["Playlists"],
        "summary": "Deletar playlist",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "playlist_id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Playlist deletada" } }
      }
    },
    "/playlists/{playlist_id}/add-audio/{audio_id}": {
      "post": {
        "tags": ["Playlists"],
        "summary": "Adicionar áudio à playlist",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "playlist_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "audio_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Áudio adicionado à playlist" } }
      }
    },
    "/playlists/{playlist_id}/remove-audio/{audio_id}": {
      "post": {
        "tags": ["Playlists"],
        "summary": "Remover áudio da playlist",
