# ─── Banco de dados ───────────────────────────────────────────────────────────
# String de conexão PostgreSQL do Supabase
# Formato: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_KEY=<ANON_PUBLIC_KEY>

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Chave secreta forte e aleatória (mín. 32 caracteres)
JWT_SECRET_KEY=<GERE_UMA_CHAVE_FORTE_AQUI>

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
